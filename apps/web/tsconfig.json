{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "react",
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@automarket/shared-types": ["../../packages/shared-types/src"],
      "@automarket/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "paths": {
      "@automarket/shared-types": ["../../packages/shared-types/src"],
      "@automarket/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
